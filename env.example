
# AÑADIR LOS PARAMETROS QUE SEAN NECESARIOS
# ── Token oficial de ESIOS (Red Eléctrica de España) ──────────────────────────
# Solicítalo en: https://www.esios.ree.es/es/pagina/api
ESIOS_TOKEN=

# ── Credenciales de tu cuenta Aqua Ariston Net ────────────────────────────────
ARISTON_USER=
ARISTON_PASS=

# Gateway del dispositivo (opcional: se autodetecta si solo tienes uno)
ARISTON_GATEWAY=

# ── Configuración de la programación ─────────────────────────────────────────
HORAS_BARATAS=4       # Número de horas baratas para calentar al día
TEMP_OBJETIVO=60     # Temperatura objetivo en °C (mínimo 55 para legionela)

# Zona geográfica PVPC:
#   8741 = Península  (la mayoría de usuarios)
#   8742 = Canarias
#   8743 = Baleares
#   8744 = Ceuta
#   8745 = Melilla
GEO_ID=8741